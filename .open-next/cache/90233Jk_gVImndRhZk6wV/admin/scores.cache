ri&#x27;, sans-serif;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);display:block;margin-bottom:4px\">League</label><input type=\"text\" style=\"width:100%;padding:8px 10px;border:1px solid var(--ink-border);background:var(--bg-surface);color:var(--ink);font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:14px;border-radius:2px\" required=\"\" lang=\"bn\" value=\"\"/></div><div class=\"grid grid-cols-2 gap-3\"><div><label style=\"font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);display:block;margin-bottom:4px\">Team A</label><input type=\"text\" style=\"width:100%;padding:8px 10px;border:1px solid var(--ink-border);background:var(--bg-surface);color:var(--ink);font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:14px;border-radius:2px\" required=\"\" lang=\"bn\" value=\"\"/></div><div><label style=\"font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);display:block;margin-bottom:4px\">Score A</label><input type=\"text\" style=\"width:100%;padding:8px 10px;border:1px solid var(--ink-border);background:var(--bg-surface);color:var(--ink);font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:14px;border-radius:2px\" value=\"0\"/></div></div><div class=\"grid grid-cols-2 gap-3\"><div><label style=\"font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-muted);display:block;margin-bottom:4px\">Team B</label><input type=\"text\" style=\"width:100%;padding:8px 10px;border:1px solid var(--ink-border);background:var(--bg-surface);color:var(--ink);font-family:&#x27;Hind Siliguri&#x27;, sans-serif;font-size:14px;border-radius:2px\" required=\"\" lang=\"bn\" value=\"\"/></div><div><label style=\"font-family:&#x27;Hind Siliguri